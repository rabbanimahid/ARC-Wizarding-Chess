import pygame
import socket
import time

# --- Configuration ---
ROBOT_IP = "192.168.1.100"  # Replace with the actual IP of your ESP-05
UDP_PORT = 4210

# Initialize network socket
sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

# Initialize Xbox Controller
pygame.init()
pygame.joystick.init()

if pygame.joystick.get_count() == 0:
    print("No Xbox controller detected. Please connect one.")
    exit()

joystick = pygame.joystick.Joystick(0)
joystick.init()
print(f"Connected to: {joystick.get_name()}")

def apply_deadzone(value, deadzone=0.15):
    """Ignores tiny stick movements to prevent drift."""
    if abs(value) < deadzone:
        return 0.0
    return value

print("Starting control loop. Press Ctrl+C to exit.")
try:
    while True:
        pygame.event.pump()

        # Left stick for movement (X, Y), Right stick X-axis for rotation
        left_x = apply_deadzone(joystick.get_axis(0))
        left_y = apply_deadzone(-joystick.get_axis(1)) # Inverted so pushing up is positive
        right_x = apply_deadzone(joystick.get_axis(3)) 

        # Format message and send
        message = f"{left_x:.2f},{left_y:.2f},{right_x:.2f}\n"
        sock.sendto(message.encode('utf-8'), (ROBOT_IP, UDP_PORT))
        
        # Send packets at ~20Hz
        time.sleep(0.05)

except KeyboardInterrupt:
    print("\nExiting...")
    sock.sendto(b"0.00,0.00,0.00\n", (ROBOT_IP, UDP_PORT))
    pygame.quit()
